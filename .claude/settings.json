{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'FILE=$(echo \"$TOOL_INPUT\" | jq -r .file_path // .path); [[ \"$FILE\" == *.go ]] && golangci-lint run $(dirname \"$FILE\")/... || exit 0'"
          }
        ]
      }
    ]
  }
}
